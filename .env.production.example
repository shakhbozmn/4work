DJANGO_SETTINGS_MODULE=config.settings.production
DEBUG=False
SECRET_KEY=generate-a-strong-secret-key

DB_NAME=4work_db
DB_USER=4work_user
DB_PASSWORD=use-a-strong-random-password
DB_HOST=db
DB_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=use-a-strong-redis-password

# Public domain used for ALLOWED_HOSTS, redirects, CSRF and CORS origins.
# Set to the hostname that fronts the deployment (no scheme, no trailing slash).
DOMAIN=example.com

ALLOWED_HOSTS=${DOMAIN}

SITE_NAME=4work
SITE_URL=https://${DOMAIN}

CORS_ALLOWED_ORIGINS=https://${DOMAIN}
CSRF_TRUSTED_ORIGINS=https://${DOMAIN}

# Fully qualified image reference consumed by the production compose file.
DOCKER_IMAGE=4work:latest
APP_PORT=443
